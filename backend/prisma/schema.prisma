generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DEALER
}

enum AuctionResult {
  SOLD
  UNSOLD
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  name         String

  bids Bid[]
}

model Vehicle {
  id               String   @id @default(uuid())
  vin              String   @unique
  make             String
  model            String
  year             Int
  mileage          Int
  batteryCapacity  Float
  batterySoH       Float
  range            Int
  registrationDate DateTime
  conditionNotes   String?
  photos           String[]
  city             String
  country          String

  auctions Auction[]
}

model Auction {
  id           String   @id @default(uuid())

  vehicleId    String
  vehicle      Vehicle @relation(fields: [vehicleId], references: [id])

  startsAt     DateTime
  endsAt       DateTime

  reservePrice Float
  minIncrement Float

  bids Bid[]

  winningBidId String? @unique
  winningBid   Bid? @relation("WinningBid", fields: [winningBidId], references: [id])

  result       AuctionResult?
}

model Bid {
  id        String   @id @default(uuid())

  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id])

  dealerId  String
  dealer    User @relation(fields: [dealerId], references: [id])

  amount    Float
  createdAt DateTime @default(now())

  winningAuction Auction? @relation("WinningBid")
}